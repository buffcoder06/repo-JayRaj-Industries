<input type="hidden" id="HdnProcessHdeSeq" name="hiddenFieldName">

<script>
	document.addEventListener('DOMContentLoaded', function () {
		var doneQuantityInput = document.getElementById('txtDoneQuantity');
		if (!doneQuantityInput) return;

		doneQuantityInput.addEventListener('input', function () {
			if (this.value.trim() === '') {
				this.value = 0;
			}
		});
	});
</script>
