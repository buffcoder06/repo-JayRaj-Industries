				<label for="poaType" class="custmLbl1">Selection<span class="colorRed">*</span></label>
				<select id="ddlSelection" name="poaType" class="form-select">
					<option value="REJ">Rejected Material</option>
					<option value="APR">Out Material</option>
				</select>
			</div>
		</div>
		<div class="col-xl-3 col-lg-6 col-md-6 col-sm-6 col-12">
			<div class="form-group formGroup2">
				<label for="Searchtext" id="idQuantity" class="custmLbl1">
					Quantity:<span class="colorRed">*</span>
				</label>
				<input type="number" class="form-control" placeholder="" id="txtDoneQuantity">
			</div>
		</div>
		<br />
		<br />
		<br />
	</div>
	<button type="button" class="btn btn-primary btnPrimary1" id="SaveChalanOut">Submit</button>
</div>

