@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
	ViewData["Title"] = "Chalan Process";
}


 

<div class="contComnDiv1">
	<div class="plainSection" id="idChalanEntry">
		<div class="secHeading">
			<i class="fa fa-bar-chart" aria-hidden="true"></i>
			Current Month Summary
		</div>
		<div class="row g-3 summaryCardsRow">
			<div class="col-xl-3 col-lg-6 col-md-6 col-sm-6 col-12">
				<div class="summaryCard summaryCard--action">
					<div class="summaryCard__label">Incoming Chalan</div>
					<button type="button" class="btn btn-primary btnPrimary1 summaryCard__btn" id="btnInCard">Add Incoming Chalan</button>
				</div>
			</div>
			<div class="col-xl-3 col-lg-6 col-md-6 col-sm-6 col-12">
				<div class="summaryCard">
					<div class="summaryCard__label">Total Out Material</div>
					<div class="summaryCard__value" id="cardTotalOutMaterial">0</div>
				</div>
			</div>
			<div class="col-xl-3 col-lg-6 col-md-6 col-sm-6 col-12">
				<div class="summaryCard">
					<div class="summaryCard__label">Total Pending Material</div>
					<div class="summaryCard__value" id="cardTotalPendingMaterial">0</div>
				</div>
			</div>
			<div class="col-xl-3 col-lg-6 col-md-6 col-sm-6 col-12">
				<div class="summaryCard">
					<div class="summaryCard__label">Total Rejected Material</div>
					<div class="summaryCard__value" id="cardTotalRejectedMaterial">0</div>
				</div>
			</div>
		</div>
	</div>

	<div class="plainSection" id="idChalanProcessGrid">
		<div class="secHeading">
			<i class="fa fa-search-plus" aria-hidden="true"></i>
			@ViewData["Title"]
		</div>
		<div class="tableHeaderFix tableHeaderFix--chalan-grid">
			<table class="table class_tableCustmSM1 table-bordered table-hover mb-0" id="tblchalanProcess">
				<thead>
					<tr>
						<th>Action</th>
						<th>
							Date
							<input type="text" class="srchTextInputCls" id="idDesign"
								   placeholder="Search Date" />
						</th>
						<th>
							Component Description
							<select class="srchTextInputCls" id="componentSearch">
								<option value="">All Components</option>
								<option value="J LWD Rear Diff Case 10013474-030">J LWD Rear Diff Case 10013474-030</option>
								<option value="J Hub Small 111.06.021.61.9">J Hub Small 111.06.021.61.9</option>
								<option value="J Case Differential 40112573(Dost Diff Case AAM)">J Case Differential 40112573(Dost Diff Case AAM)</option>
								<option value="J P Diff Case 112.04.001.61.9-PDNS3404145012">J P Diff Case 112.04.001.61.9-PDNS3404145012</option>
								<option value="J Wheel Hub 708.06.0003.63.9">J Wheel Hub 708.06.0003.63.9</option>
								<option value="J Diff Case Eld s/f M180 Flange Half 10019886">J Diff Case Eld s/f M180 Flange Half 10019886</option>
								<option value="J Diff Case Flange Half Rgh Spilt - 2015985">J Diff Case Flange Half Rgh Spilt - 2015985</option>
								<option value="J Mcie-3.3L Front Hub 0503Gaa 0047">J Mcie-3.3L Front Hub 0503Gaa 0047</option>
								<option value="J Diff Case S20Dc103">J Diff Case S20Dc103</option>
								<option value="J Diff Case S20Dc104">J Diff Case S20Dc104</option>
								<option value="J Diff Case 32931">J Diff Case 32931</option>
								<option value="J P-375 Rear Diff Case 10043997">J P-375 Rear Diff Case 10043997</option>
								<option value="J Diff Cover R252596-A130E1(Sona)">J Diff Cover R252596-A130E1(Sona)</option>
							</select>
						</th>
						<th>
							Chalan No
							<input type="text" class="srchTextInputCls" id="idReqEntityID"
								   placeholder="Search Chalan No" />
						</th>
						<th>
							Quantity
							<input type="text" class="srchTextInputCls" id="idReqEntityName"
								   placeholder="Search  Quantity" />
						</th>
						<th>
							Pending Material
							<input type="text" class="srchTextInputCls" id="idDesign"
								   placeholder="Search Pending Material" />
						</th>
					</tr>
				</thead>
				<tbody>
				</tbody>
			</table>
		</div>
	</div>
</div>
<div class="contComnDiv1" id="idChalanOut" style="display:none">
	<div class="row">
		<div class="secHeading">
			<i class="fa fa-search-plus" aria-hidden="true"></i>
