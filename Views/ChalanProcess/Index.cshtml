			<div class="form-group formGroup2">
				<label for="poaSubType" class="custmLbl1">Components Description:<span class="colorRed">*</span></label>
				<input type="text" class="form-control" placeholder="" id="txtComponentDesc" disabled>
			</div>
		</div>
		<div class="col-xl-3 col-lg-6 col-md-6 col-sm-6 col-12">
